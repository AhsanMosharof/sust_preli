# QueueStorm Investigator — Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

PORT=8000

# LLM Provider: gemini (recommended — free tier, best Bangla support)
LLM_PROVIDER=gemini

# Get your free API key at: https://aistudio.google.com/
GEMINI_API_KEY=

# Model selection — gemini-2.5-flash is the recommended model (fastest + free)
MODEL_NAME=gemini-2.5-flash

# Hard timeout in seconds for LLM call (judge limit is 30s, we cut at 20s)
LLM_TIMEOUT_SECONDS=20
